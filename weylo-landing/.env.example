# PRODUCTION CONFIGURATION
# API Configuration
# URL de base de l'API backend (Laravel)
VITE_API_URL=https://weylo-adminpanel.space/api/v1

# Laravel Reverb WebSocket Configuration
# Configuration pour la communication temps réel (chat, notifications, etc.)
# Connection: wss://weylo-adminpanel.space:443/app/1425cdd3ef7425fa6746d2895a233e52
VITE_REVERB_HOST=weylo-adminpanel.space
VITE_REVERB_PORT=443
VITE_REVERB_APP_KEY=1425cdd3ef7425fa6746d2895a233e52
VITE_REVERB_SCHEME=https

# App Store Links
VITE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.weylo.app
